.DS_Store
.build/
.swiftpm/
dist/

# AI tool local state — personal, not for repo
.qwen/
.claude/settings.local.json
.claude/.session/
.claude/worktrees/

# Bench output: runs and live recordings are local exploratory data.
# RESULTS.md and results.csv stay committed as canonical reference.
scripts/bench-output/live-*/
scripts/bench-output/run-*.log

# Local Xcode metadata
**/xcuserdata/
**/*.xcuserstate

# Derived artwork generated during local packaging
artwork/derived/

# Local signing config (contains your developer certificate identity)
.signing-env

# Personal dictation log — private data (what you dictated, what whisper heard)
# Drives initial_prompt iteration but must not leak to public GitHub.
hotwords-log.md

# Private architecture / decision notes. Public ADRs go in docs/decisions/ directly.
docs/decisions/private/
.gstack/
Tests/Fixtures/bench/.bench-device
